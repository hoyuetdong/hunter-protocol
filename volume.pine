//@version=6
indicator("Hunter's X-Ray Volume (VSA Logic)", shorttitle="HunterXVol", format=format.volume, overlay=false)

// ============================
// Inputs
// ============================
length = input.int(20, "Average Period")
volFactor = input.float(1.5, "High Volume Factor (x Avg)")
sqFactor  = input.float(0.8, "Squat Factor (Spread < x Avg)")

// ============================
// Calculations
// ============================
avgVol = ta.sma(volume, length)
avgRange = ta.sma(high - low, length)
range_ = high - low

// 1. volume status
isHighVol = volume > avgVol * volFactor
isUltraVol = volume > avgVol * 2.0
isLowVol  = volume < avgVol * 0.8

// 2. Spread status
isWideRange = range_ > avgRange
isNarrowRange = range_ < avgRange * sqFactor

// 3. Price Direction (Close relative to prior close)
isUp = close > close[1]
isDown = close < close[1]

// ============================
// 裡子邏輯 (The Hidden Game)
// ============================

// A. 吸收/角力 (Churning / Absorption) —— 【最重要！】
// 定義：成交量極大，但價格郁動極細 (Range 窄)。
// 解讀：有人瘋狂掛單接貨 (Buy Limit) 或派貨 (Sell Limit)，鎖死咗價格。
// 這是「裡子」鬥爭最激烈的時候。
isChurn = isHighVol and isNarrowRange

// B. 高潮/力竭 (Climax)
// 定義：成交量超大，Range 超大。
// 解讀：這是情緒發洩。通常係轉勢前夕 (Stopping Volume)。
isClimax = isUltraVol and isWideRange

// C. 正常推動 (Drive)
// 定義：成交量大，Range 大，方向一致。
// 解讀：這是健康的趨勢。
isGreenDrive = isHighVol and isWideRange and isUp and not isClimax
isRedDrive   = isHighVol and isWideRange and isDown and not isClimax

// ============================
// Color Coding
// ============================
// 橙色 = 裡子盤 (吸收/猶豫) - 重點關注！
// 紫色 = 高潮盤 (力竭) - 準備反轉
// 綠色 = 真突破 (健康買盤)
// 紅色 = 真拋售 (健康賣盤)
// 灰色 = 冇野睇 (散戶時間)

barColor = isChurn ? color.new(color.orange, 0) : 
           isClimax ? color.new(color.purple, 0) : 
           isGreenDrive ? color.new(#00E676, 0) : 
           isRedDrive ? color.new(#FF5252, 0) : 
           color.new(color.gray, 60)

// ============================
// Plotting
// ============================
plot(volume, style=plot.style_columns, color=barColor, title="X-Ray Volume")
plot(avgVol, color=color.yellow, title="Avg Vol")

// 標籤提示 (Optional)
plotshape(isChurn, title="Churn (Absorption)", style=shape.circle, location=location.absolute, color=color.orange, size=size.tiny, offset=0)